NODE_ENV=development
PORT=5000

# Database (PostgreSQL for production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=karyarambha_db
DB_USER=postgres
DB_PASSWORD=your_password

# SQLite for local development (set USE_SQLITE=true)
USE_SQLITE=true

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Admin seed account
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@karyarambha.com
ADMIN_PASSWORD=Admin@1234
